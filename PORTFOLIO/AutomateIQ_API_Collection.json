      "item": [
        {
          "name": "1.1 POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/api/auth/login","host":["{{baseUrl}}"],"path":["api","auth","login"]},
            "body": {"mode":"raw","raw":"{\n  \"email\": \"admin@automateiq.com\",\n  \"password\": \"admin123\"\n}"}
          },
          "event": [{"listen":"test","script":{"exec":[
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('success true', () => pm.expect(res.success).to.be.true);",
            "pm.test('Token received', () => pm.expect(res.data.token).to.be.a('string'));",
            "pm.environment.set('adminToken', res.data.token);",
            "console.log('✅ adminToken auto-set in environment');"
